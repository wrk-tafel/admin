{
  "name": "@tafel/admin",
  "version": "0.0.1",
  "description": "Tafel Admin",
  "contributors": [
    {
      "name": "Stephan Prantl"
    }
  ],
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve --host=0.0.0.0 --configuration=development",
    "build-local": "ng build --progress",
    "build-prod": "ng build --configuration=production --progress",
    "test": "ng test",
    "test-ci": "ng test --watch=false",
    "lint": "ng lint",
    "cy:run-ci": "wait-on -l -d 10000 tcp:8080 && cypress run --browser chrome --config baseUrl=http://localhost:8080/",
    "cy:run-ci-local": "wait-on -l -d 10000 tcp:4200 && cypress run --browser chrome --config baseUrl=http://localhost:4200/",
    "cy:open-ci": "cypress open --browser chrome --config baseUrl=http://localhost:8080/",
    "cy:open-local": "cypress open --browser chrome"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.9",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/localize": "21.2.11",
    "@angular/material": "21.2.9",
    "@angular/platform-browser": "21.2.11",
    "@angular/platform-browser-dynamic": "21.2.11",
    "@angular/router": "21.2.11",
    "@coreui/angular": "5.6",
    "@coreui/angular-chartjs": "5.6",
    "@coreui/chartjs": "4.2.0",
    "@coreui/coreui": "5.6.1",
    "@coreui/icons": "3.1.0",
    "@coreui/icons-angular": "5.6",
    "@coreui/utils": "2.0.2",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@tailwindcss/postcss": "4.2.4",
    "bootstrap": "5.3.8",
    "chart.js": "4.5.1",
    "core-js": "3.49.0",
    "html5-qrcode": "2.3.8",
    "moment": "2.30.1",
    "ng2-charts": "10.0.0",
    "ngx-cookie-service": "21.3.1",
    "ngx-scrollbar": "19.1.4",
